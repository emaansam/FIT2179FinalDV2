{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

    "height":400,
    "width":200,
  
    "data": {
      "url": "rank.csv"
    },
  
    "mark": "bar",
  
    "encoding": {
      "x": {
        "field": "selective",
        "type": "nominal",
        "title": "Selective School"
      },
      "y": {
        "aggregate": "count",
        "title": "Number of Schools"
      },
      "color": {
        "field": "selective",
        "type": "nominal",
        "title": "Selective",
        "scale": {
          "range": ["#686ca1", "#8abac2"]
        }
      },
      "tooltip": [
        {"aggregate": "count", "title": "Number of Schools"},
        {"field": "selective", "title": "Selective"}
      ]
    },
    "config": {
        "view": {"stroke": null},
        "font": "Georgia, serif"
      }
  }
  