        {"school": "Presbyterian Ladies' College", "r24": 17, "r25": 20},
        {"school": "Yarra Valley Grammar School", "r24": 35, "r25": 21},
        {"school": "St Kevin's College", "r24": 22, "r25": 22},
        {"school": "Methodist Ladies College", "r24": 27, "r25": 23},
        {"school": "Firbank Grammar School", "r24": 34, "r25": 24},
        {"school": "Lauriston Girl's School", "r24": 38, "r25": 25}
      ]
    },
    "transform": [
      {"calculate": "datum.r24 - datum.r25", "as": "change"},
      {"calculate": "datum.change > 0 ? 'Moved Up' : datum.change < 0 ? 'Dropped' : 'No Change'", "as": "direction"},
      {"calculate": "datum.change > 0 ? 'Moved up ' + datum.change + ' places' : datum.change < 0 ? 'Dropped ' + abs(datum.change) + ' places' : 'No change'", "as": "changeLabel"}
    ],
    "layer": [
      {
        "mark": {"type": "bar"},
        "encoding": {
          "y": {
            "field": "school",
            "type": "nominal",
            "sort": {"field": "r25", "op": "min", "order": "ascending"},
            "axis": {"title": null, "labelFontSize": 11, "labelLimit": 260, "ticks": false, "domainColor": "#cccccc"}
          },
          "x": {
            "field": "change",
            "type": "quantitative",
            "title": "Number of Rank Places",
            "axis": {"gridColor": "#e8e8e8", "domainColor": "#cccccc", "tickCount": 8}
          },
          "color": {
            "field": "direction",
            "type": "nominal",
            "scale": {"domain": ["Moved Up", "No Change", "Dropped"], "range": ["#2ab363", "#aaaaaa", "#5c6ed6"]},
            "legend": {"title": null, "orient": "top", "symbolType": "square", "symbolSize": 120, "labelFontSize": 12}
          },
          "tooltip": [
            {"field": "school", "type": "nominal", "title": "School"},
            {"field": "r24", "type": "quantitative", "title": "2024 Rank"},
            {"field": "r25", "type": "quantitative", "title": "2025 Rank"},
            {"field": "changeLabel", "type": "nominal", "title": "Change"}
          ]
        }
      },
      {
        "transform": [{"filter": "datum.change === 0"}],
        "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 10, "fontStyle": "italic", "color": "#888888"},
        "encoding": {
          "y": {"field": "school", "type": "nominal", "sort": {"field": "r25", "op": "min", "order": "ascending"}},
          "x": {"value": 0},
          "text": {"value": "No Change"}
        }
      }
    ],
    "config": {
      "view": {"stroke": null},
      "bar": {"size": 16},
      "font": "Georgia, serif",
      "padding": {"left": 10, "right": 30, "top": 20, "bottom": 20}
    }
  }
  