        {"school": "Melbourne High School", "r24": 10, "r25": 8},
        {"school": "Melbourne Grammar School", "r24": 11, "r25": 9},
        {"school": "Huntingover School", "r24": 2, "r25": 10},
        {"school": "Camberwell Girls Grammar School", "r24": 19, "r25": 11},
        {"school": "Fintona Girls School", "r24": 13, "r25": 12},
        {"school": "Haileybury College", "r24": 15, "r25": 13},
        {"school": "Mount Scopus Memorial College", "r24": 4, "r25": 14},
        {"school": "Suzanne Cory High School", "r24": 44, "r25": 15},
        {"school": "Bialik College", "r24": 8, "r25": 16},
        {"school": "Loreto Mandevile Hall", "r24": 14, "r25": 17},
