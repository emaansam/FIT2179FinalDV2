{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title":
    {
      "text": "School Rankings Change from 2024 to 2025",
      "fontSize": 16,
      "subtitle": "Note: Schools on the Y-Axis are listed in order of their ranking, as of 2025.",
      "subtitleFontSize": 14,
      "anchor": "start",
      "offset": 12
    },
    "width": 450,
    "height": 620,
    "data": {
      "values": [
        {"school": "Ballarat Clarendon College", "r24": 1, "r25": 1},
        {"school": "MacRobertson Girls High School", "r24": 3, "r25": 2},
