{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Ranks of Rising Schools (2025)",
    "fontSize": 16,
    "anchor": "start",
    "offset": 12
  },
  "width": 500,
  "height": 500,

  "data": {
    "url": "other.csv"
  },

  "transform": [
    {
      "fold": ["rank2024", "rank2025"],
      "as": ["Year", "Rank"]
    },
    {
      "calculate": "datum.Year === 'rank2024' ? 2024 : 2025",
      "as": "YearNum"
    }
  ],

  "encoding": {
    "x": {
      "field": "YearNum",
      "type": "ordinal",
      "title": "",
      "axis": {"labelAngle": 0},
      "scale": {
        "padding": 0,
        "paddingInner": 0,
        "paddingOuter": 0
      }
    },
    "y": {
      "field": "Rank",
      "type": "quantitative",
      "title": "Rank",
      "sort": "ascending"
    },
    "color": {
      "field": "school",
      "type": "nominal",
      "title": "School",
      "scale": {
        "range": [
          "#0072B2",
          "#365c3b",
          "#009E73",
          "#575b91",
          "#227185"
        ]
      }
    }
  },

  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 200
      },
      "encoding": {
        "tooltip": [
          {"field": "school", "title": "School"},
          {"field": "rank2024", "title": "Rank 2024"},
          {"field": "rank2025", "title": "Rank 2025"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Georgia, serif"
  }
}
